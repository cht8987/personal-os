#!/bin/bash
# rtk — OBSIDIAN AI OS 统一 CLI 入口（一切系统操作的唯一通道）
set -euo pipefail

# 解析软链（如 ~/.local/bin/pos → 库内 rtk），确保 ROOT 始终指向真实库根
SRC="${BASH_SOURCE[0]}"
while [ -h "$SRC" ]; do
  DIR="$(cd -P "$(dirname "$SRC")" && pwd)"
  SRC="$(readlink "$SRC")"
  [ "${SRC#/}" = "$SRC" ] && SRC="$DIR/$SRC"
done
BIN_DIR="$(cd -P "$(dirname "$SRC")" && pwd)"
ROOT="$(cd "$BIN_DIR/../../.." && pwd)"
LIB="$ROOT/03-Agents/automation/lib"
PY="${RTK_PYTHON:-python3}"
# 库外密钥配置（由插件设置页写入，符合 S3 铁律）
[ -f "$HOME/.personal-os/llm.env" ] && set -a && . "$HOME/.personal-os/llm.env" && set +a
CRON_LINE="30 23 * * * \"$BIN_DIR/rtk\" patrol >> \"$ROOT/.system/logs/cron.log\" 2>&1"

usage() {
  cat <<EOF
rtk — OBSIDIAN AI OS 统一入口

用法:
  rtk onboard            新人引导：交互式设定个人画像（profile）
  rtk ingest "文本"      凌乱文本 → 结构化推入 01-Inbox（也支持管道输入）
  rtk patrol             手动触发 Hermes 日巡检（队列消化+分发+ops-log）
  rtk refine             AI 蒸馏：精修 static 结构与双链 + 消化慢车道 Inbox（需 LLM Key）
  rtk memsync            Obsidian→Hindsight 记忆同步（static 区增量入语义库）
  rtk backup [目标目录]  全量备份：库 + Hermes 核心 + Hindsight 数据 → 三个 tar.gz（默认 POS_BACKUP_DEST）
  rtk backup-auto on|off 每日 22:30 自动备份（launchd）
  rtk status             系统健康状态
  rtk install-cron       注册每晚 23:30 自动巡检（crontab 方式）
  rtk uninstall-cron     移除 crontab 巡检
  rtk install-launchd    注册每晚 23:30 自动巡检（macOS launchd，推荐：睡眠错过会补跑）
  rtk uninstall-launchd  移除 launchd 巡检
  rtk help               本帮助
EOF
}

PLIST="$HOME/Library/LaunchAgents/com.personalos.patrol.plist"

case "${1:-help}" in
  onboard)
    "$PY" "$LIB/onboard.py"
    ;;
  ingest)
    shift
    if [ $# -gt 0 ]; then "$PY" "$LIB/ingest.py" "$@"; else "$PY" "$LIB/ingest.py"; fi
    ;;
  patrol)
    "$PY" "$LIB/patrol.py"
    ;;
  refine)
    "$PY" "$LIB/refine.py"
    ;;
  memsync)
    SYNC="$HOME/.elson-os-index/lib/obsidian_sync.py"
    if [ -f "$SYNC" ]; then "$PY" "$SYNC" "${2:---incremental}"; else echo "未检测到 Hindsight 同步管线（可选组件）"; fi
    ;;
  backup)
    DEST="${2:-${POS_BACKUP_DEST:-$HOME/PersonalOS-Backups}}"
    STAMP="$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$DEST" || { echo "❌ 目标不可写：$DEST（NAS 挂载了吗？）"; exit 1; }
    echo "备份目标: $DEST"
    # 1) Obsidian 库（排除插件缓存与日志）
    tar -czf "$DEST/vault-$STAMP.tar.gz" -C "$(dirname "$ROOT")"       --exclude='*/node_modules' --exclude='*/.system/logs' "$(basename "$ROOT")"       && echo "  ✅ vault-$STAMP.tar.gz"
    # 2) Hermes：委托成熟脚本（NAS等待/原子写/30天保留），否则通用 tar
    if [ -x "$HOME/.hermes/scripts/hermes-backup-nas.sh" ]; then
      bash "$HOME/.hermes/scripts/hermes-backup-nas.sh" && echo "  ✅ hermes（委托 hermes-backup-nas.sh → Hermas Backup/）" || echo "  ⚠️ hermes 备份脚本失败"
    elif [ -d "$HOME/.hermes" ]; then
      tar -czf "$DEST/hermes-core-$STAMP.tar.gz" -C "$HOME" \
        --exclude='.hermes/hermes-agent' --exclude='.hermes/hermes-office' \
        --exclude='.hermes/hermes-skill-factory' --exclude='.hermes/rtk-hermes' \
        --exclude='.hermes/*cache*' --exclude='.hermes/node' --exclude='.hermes/bin' \
        --exclude='.hermes/lsp' --exclude='.hermes/sandboxes' --exclude='.hermes/sessions' \
        --exclude='.hermes/state.db*' --exclude='.hermes/state-snapshots' \
        --exclude='.hermes/logs' --exclude='.hermes/hermes-setup' \
        .hermes && echo "  ✅ hermes-core-$STAMP.tar.gz"
    fi
    # 3) Hindsight：委托 PG 逻辑 dump（容器内 pg_dump，防 WAL 损坏），不在则跳过
    if [ -x "$HOME/.hermes/scripts/hindsight-pg-dump-nas.sh" ]; then
      bash "$HOME/.hermes/scripts/hindsight-pg-dump-nas.sh" && echo "  ✅ hindsight（pg_dump → Hindsight Backup/）" || echo "  ⚠️ hindsight dump 失败/跳过"
    fi
    # 统一保留策略：日备 7 天自动清理（带标签的里程碑快照不受影响；周镜像 28 天）
    find "$DEST" -maxdepth 1 -name 'vault-*.tar.gz' -mtime +7 -delete 2>/dev/null || true
    find "$DEST" -maxdepth 1 -name 'pre-sync-*.tar.gz' -mtime +7 -delete 2>/dev/null || true
    if [ -d "$HOME/PersonalOS-Backups/hermes" ]; then
      find "$HOME/PersonalOS-Backups/hermes" -maxdepth 1 -name 'hermes-2*.tar.gz' -mtime +7 -delete 2>/dev/null || true
      find "$HOME/PersonalOS-Backups/hermes" -maxdepth 1 -name 'hermes-self-evolution-output-*.tar.gz' -mtime +7 -delete 2>/dev/null || true
      find "$HOME/PersonalOS-Backups/hermes" -maxdepth 1 -name 'hermes-core-*.tar.gz' -mtime +7 -delete 2>/dev/null || true
    fi
    if [ -d "$HOME/PersonalOS-Backups/hindsight" ]; then
      find "$HOME/PersonalOS-Backups/hindsight" -maxdepth 1 -name 'hindsight-pgdump-2*.sql.gz' -mtime +7 -delete 2>/dev/null || true
      find "$HOME/PersonalOS-Backups/hindsight" -maxdepth 1 -name 'hindsight-2*.tar.gz' -mtime +7 -delete 2>/dev/null || true
    fi
    echo "  🧹 7天保留策略已执行（里程碑快照与镜像豁免）"
    echo "$(date '+%Y-%m-%d %H:%M:%S') backup → $DEST" >> "$ROOT/.system/logs/backup.log"
    echo "✅ 备份完成（日备保留7天）"
    ;;
  backup-auto)
    BPLIST="$HOME/Library/LaunchAgents/com.personalos.backup.plist"
    if [ "${2:-on}" = "off" ]; then
      launchctl unload "$BPLIST" 2>/dev/null || true; rm -f "$BPLIST"
      echo "✅ 自动备份已关闭"
    else
      # TCC：用已授权 FDA 的 python 真身作为责任进程，子进程 tar 才能读 iCloud
      PYBIN="$("$PY" -c 'import os,sys; print(os.path.realpath(sys.executable))')"
      cat > "$BPLIST" <<BEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.personalos.backup</string>
  <key>ProgramArguments</key>
  <array>
    <string>$PYBIN</string>
    <string>-c</string>
    <string>import subprocess; subprocess.run(["/bin/bash", "$BIN_DIR/rtk", "backup"])</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>22</integer><key>Minute</key><integer>30</integer></dict>
  <key>StandardOutPath</key><string>$ROOT/.system/logs/backup.log</string>
  <key>StandardErrorPath</key><string>$ROOT/.system/logs/backup.log</string>
</dict>
</plist>
BEOF
      launchctl unload "$BPLIST" 2>/dev/null || true
      launchctl load "$BPLIST"
      echo "✅ 自动备份已开启：每日 22:30（vault + Hermes 核心 + Hindsight → NAS）"
    fi
    ;;
  status)
    echo "=== OBSIDIAN AI OS 状态 ==="
    echo "根目录   : $ROOT"
    [ -d "$ROOT/01-Inbox" ] && echo "目录完整 : ✅" || echo "目录完整 : ❌ 01-Inbox 缺失"
    q=$(find "$ROOT/01-Inbox/.queue" -name '*.txt' 2>/dev/null | wc -l | tr -d ' ')
    i=$(find "$ROOT/01-Inbox" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    echo "队列积压 : $q 条"
    echo "Inbox待分发: $i 条"
    if [ -f "$ROOT/.system/logs/patrol.log" ]; then
      echo "上次巡检 : $(tail -1 "$ROOT/.system/logs/patrol.log")"
    else
      echo "上次巡检 : 从未运行"
    fi
    model="${SILICONFLOW_MODEL:-nex-agi/Nex-N2-Pro}"
    if [ -n "${SILICONFLOW_API_KEY:-}" ]; then
      echo "LLM      : siliconflow ✅ ($model)"
    else
      echo "LLM      : 未配置(offline 规则引擎降级) ⚠️"
    fi
    ;;
  install-cron)
    (crontab -l 2>/dev/null | grep -vF "$BIN_DIR/rtk\" patrol"; echo "$CRON_LINE") | crontab -
    echo "✅ 已注册: $CRON_LINE"
    ;;
  uninstall-cron)
    crontab -l 2>/dev/null | grep -vF "$BIN_DIR/rtk\" patrol" | crontab -
    echo "✅ 已移除巡检 Cron"
    ;;
  install-launchd)
    mkdir -p "$HOME/Library/LaunchAgents" "$ROOT/.system/logs"
    # TCC 按可执行文件真实路径精确匹配授权，必须解析掉所有 stub/symlink
    PYBIN="$("$PY" -c 'import os,sys; print(os.path.realpath(sys.executable))')"
    cat > "$PLIST" <<PEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.personalos.patrol</string>
  <key>ProgramArguments</key>
  <array>
    <string>$PYBIN</string>
    <string>$LIB/patrol.py</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>23</integer><key>Minute</key><integer>30</integer></dict>
  <key>StandardOutPath</key><string>$ROOT/.system/logs/launchd.log</string>
  <key>StandardErrorPath</key><string>$ROOT/.system/logs/launchd.log</string>
</dict>
</plist>
PEOF
    # 每周日 22:00 蒸馏（refine）
    RPLIST="$HOME/Library/LaunchAgents/com.personalos.refine.plist"
    sed -e 's/com.personalos.patrol/com.personalos.refine/' \
        -e 's|patrol.py|refine.py|' \
        -e 's|<dict><key>Hour</key><integer>23</integer><key>Minute</key><integer>30</integer></dict>|<dict><key>Weekday</key><integer>0</integer><key>Hour</key><integer>22</integer><key>Minute</key><integer>0</integer></dict>|' \
        "$PLIST" > "$RPLIST"
    launchctl unload "$RPLIST" 2>/dev/null || true
    launchctl load "$RPLIST"
    launchctl unload "$PLIST" 2>/dev/null || true
    launchctl load "$PLIST"
    echo "✅ launchd 已注册：每晚 23:30 巡检 + 每周日 22:00 AI 蒸馏"
    echo "   手动触发验证: launchctl start com.personalos.patrol"
    ;;
  uninstall-launchd)
    launchctl unload "$PLIST" 2>/dev/null || true
    rm -f "$PLIST"
    echo "✅ 已移除 launchd 巡检"
    ;;
  help|--help|-h) usage ;;
  *) echo "未知命令: $1"; usage; exit 1 ;;
esac
